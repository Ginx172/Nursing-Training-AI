# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# MCP and RAG Service Endpoints
MCP_ENDPOINT=http://localhost:8001
RAG_ENDPOINT=http://localhost:8002

# Knowledge Base Configuration
KNOWLEDGE_BASE_PATH=J:/_Proiect_Nursing_training_AI/Healthcare_Knowledge_Base

# Database Configuration
DATABASE_URL=sqlite:///./nursing_training.db

# CORS Configuration
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:3001"]
ALLOWED_HOSTS=["localhost", "127.0.0.1"]

# Logging Configuration
LOG_LEVEL=INFO

# Evaluation Configuration
EVALUATION_TIMEOUT=60
MAX_EVALUATION_RETRIES=3

# Payments / Webhooks
STRIPE_WEBHOOK_SECRET=replace_with_real_secret

# Logs
TELEMETRY_DIR=logs/analytics
AUDIT_DIR=logs/audit
