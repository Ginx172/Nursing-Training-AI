# 🏥 Nursing Training AI - Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
APP_NAME=Nursing Training AI
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
HOST=0.0.0.0
PORT=8000

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DATABASE_URL=postgresql://nursing_user:nursing_password@localhost:5432/nursing_training_ai
DATABASE_URL_TEST=postgresql://nursing_user:nursing_password@localhost:5432/nursing_training_ai_test

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# JWT AUTHENTICATION
# ============================================================================
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================================
# AI SERVICES CONFIGURATION
# ============================================================================
# OpenAI API Key (required for MCP service)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4

# RAG System Configuration
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200

# MCP System Configuration
MCP_ENDPOINT=http://localhost:8001
MCP_CONTEXT_SIZE=4096

# Knowledge Base Configuration
KNOWLEDGE_BASE_PATH=J:/_Proiect_Nursing_training_AI/Healthcare_Knowledge_Base

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001
ALLOWED_HOSTS=*

# ============================================================================
# FILE STORAGE
# ============================================================================
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# ============================================================================
# EMAIL CONFIGURATION (for future use)
# ============================================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ============================================================================
# PAYMENT CONFIGURATION (for future use)
# ============================================================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
AUDIT_LOG_PATH=./logs/audit.log
TELEMETRY_LOG_PATH=./logs/telemetry.log

# ============================================================================
# GEOLOCATION (for future use)
# ============================================================================
GEOIP_DB_PATH=./data/GeoLite2-Country.mmdb
