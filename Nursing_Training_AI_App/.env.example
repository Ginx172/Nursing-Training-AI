# 🔧 Environment Variables pentru Nursing Training AI

# Aplicație
APP_NAME=Nursing Training AI
APP_VERSION=1.0.0
DEBUG=True

# Server
HOST=0.0.0.0
PORT=8000

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001

# Baza de date
DATABASE_URL=postgresql://nursing_user:nursing_password@localhost:5432/nursing_training_ai
DATABASE_URL_TEST=postgresql://nursing_user:nursing_password@localhost:5432/nursing_training_ai_test

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI Services
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4

# RAG System
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200

# MCP System
MCP_MODEL_PATH=
MCP_CONTEXT_SIZE=4096

# File Storage
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# Email (pentru viitor)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Payment (pentru viitor)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Nursing Training AI
NEXT_PUBLIC_APP_VERSION=1.0.0
