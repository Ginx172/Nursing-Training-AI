# OpenAI API Configuration (or use GEMINI_API_KEY for Gemini)
# Obtain from https://platform.openai.com/api-keys
OPENAI_API_KEY=CHANGE_ME_OPENAI_API_KEY

# MCP and RAG Service Endpoints
MCP_ENDPOINT=http://localhost:8001
RAG_ENDPOINT=http://localhost:8002

# Knowledge Base Configuration
# Set to the absolute path of the Healthcare_Knowledge_Base directory on your system
KNOWLEDGE_BASE_PATH=CHANGE_ME_PATH_TO_KNOWLEDGE_BASE

# Database Configuration (PostgreSQL — must match DATABASE_URL in root .env.example)
# Generate a secure password and use the same value in POSTGRES_PASSWORD below
DATABASE_URL=postgresql://nursing_user:CHANGE_ME_DB_PASSWORD@localhost:5432/nursing_training_ai
DATABASE_URL_TEST=postgresql://nursing_user:CHANGE_ME_DB_PASSWORD@localhost:5432/nursing_training_ai_test

# PostgreSQL superuser password (used by docker-compose)
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
POSTGRES_USER=nursing_user
POSTGRES_DB=nursing_training_ai

# JWT
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_SECRET_KEY_MIN_32_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001

# Logging Configuration
LOG_LEVEL=INFO

# Evaluation Configuration
EVALUATION_TIMEOUT=60
MAX_EVALUATION_RETRIES=3

# Payments / Webhooks
STRIPE_WEBHOOK_SECRET=CHANGE_ME_STRIPE_WEBHOOK_SECRET

# Logs
TELEMETRY_DIR=logs/analytics
AUDIT_DIR=logs/audit
