# 🔧 Environment Variables pentru Nursing Training AI

# Aplicație
APP_NAME=Nursing Training AI
APP_VERSION=1.0.0
DEBUG=True

# Server
HOST=0.0.0.0
PORT=8000

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001

# Baza de date
# Generate a secure password and set it here AND in POSTGRES_PASSWORD below
DATABASE_URL=postgresql://nursing_user:CHANGE_ME_DB_PASSWORD@localhost:5432/nursing_training_ai
DATABASE_URL_TEST=postgresql://nursing_user:CHANGE_ME_DB_PASSWORD@localhost:5432/nursing_training_ai_test

# PostgreSQL superuser password (used by docker-compose)
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
POSTGRES_USER=nursing_user
POSTGRES_DB=nursing_training_ai

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_SECRET_KEY_MIN_32_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI Services
# Obtain from https://platform.openai.com/api-keys
OPENAI_API_KEY=CHANGE_ME_OPENAI_API_KEY
OPENAI_MODEL=gpt-4

# RAG System
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200

# MCP System
MCP_MODEL_PATH=
MCP_CONTEXT_SIZE=4096

# File Storage
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# Email (pentru viitor)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Payment (pentru viitor)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Nursing Training AI
NEXT_PUBLIC_APP_VERSION=1.0.0
