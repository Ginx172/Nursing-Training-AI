      "job_title": "Associate Practitioner / Specialist Healthcare Assistant",
      "typical_responsibilities": [
        "Perform specific clinical procedures",
        "Undertake patient assessments",
        "Mentor junior staff and students",
        "Contribute to care planning",
        "Participate in audits and quality improvement",
        "Lead specific patient groups or conditions"
      ],
      "key_competencies": [
