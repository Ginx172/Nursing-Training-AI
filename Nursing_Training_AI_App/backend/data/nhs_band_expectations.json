{
  "nhs_band_expectations": {
    "band_2": {
      "job_title": "Healthcare Assistant / Support Worker",
      "typical_responsibilities": [
        "Assist registered nurses with basic patient care",
        "Take and record vital signs under supervision",
        "Help patients with personal care and mobility",
        "Maintain clean and safe environment",
        "Report concerns to senior staff",
        "Follow established protocols and procedures"
      ],
      "key_competencies": [
        "Basic clinical skills",
        "Communication with patients and families",
        "Teamwork and collaboration",
        "Following instructions accurately",
        "Basic record keeping",
        "Infection prevention and control"
      ],
      "autonomy_level": "Minimal - Works under direct supervision",
      "decision_making": "Limited - Follows established procedures",
      "leadership_expectations": "None",
      "typical_experience": "New to healthcare or limited experience",
      "education_requirements": "Care Certificate or equivalent",
      "example_interview_questions": [
        "Why do you want to work as a Healthcare Assistant?",
        "How would you help a patient with limited mobility?",
        "What would you do if you noticed a patient was unwell?",
        "How do you ensure patient dignity?"
      ]
    },
    "band_3": {
      "job_title": "Senior Healthcare Assistant / Assistant Practitioner",
      "typical_responsibilities": [
        "Provide care for patients with complex needs",
        "Assist with clinical procedures",
        "Support newly qualified nurses",
        "Contribute to patient assessments",
        "Maintain accurate documentation",
        "Participate in quality improvement activities"
      ],
      "key_competencies": [
        "Enhanced clinical skills",
        "Basic supervision of Band 2 staff",
        "Patient assessment basics",
        "Clinical documentation",
        "Supporting student learning",
        "Quality improvement awareness"
      ],
      "autonomy_level": "Low - Works with minimal supervision for routine tasks",
      "decision_making": "Limited - Can make routine decisions, escalates complex issues",
      "leadership_expectations": "Minimal - May support junior staff",
      "typical_experience": "1-2 years in healthcare",
      "education_requirements": "NVQ Level 3 or Foundation Degree",
      "example_interview_questions": [
        "How do you prioritize your workload?",
        "Describe a time you supported a junior colleague",
        "How would you handle a challenging patient?",
        "What is your understanding of safeguarding?"
      ]
    },
